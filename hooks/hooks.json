{
  "description": "Documentation lifecycle management - edit detection and freshness checks",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/wrapper.sh chronicler edit",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/wrapper.sh chronicler stop",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
